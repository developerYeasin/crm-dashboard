# Flask Configuration
SECRET_KEY=your-secret-key-change-in-production
PORT=8087
DEBUG=False

# MySQL Database Configuration (using existing order_tracker DB)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=order_user
MYSQL_PASSWORD=order_pass_123!
MYSQL_DB=order_tracker

# Admin Password for initial login (used by init_db)
ADMIN_PASSWORD=admin123

# Email Configuration (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# Slack Integration (optional)
SLACK_WEBHOOK_URL=

# AI/Claude Integration via OpenRouter
ANTHROPIC_BASE_URL=https://openrouter.ai/api
ANTHROPIC_AUTH_TOKEN=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
ANTHROPIC_MODEL=stepfun/step-3.5-flash:free

# Cache settings (optional)
CACHE_ENABLED=true
CACHE_TYPE=database
CACHE_TTL_AI_RESPONSE=86400
CACHE_TTL_AI_STATELESS=3600
CACHE_TTL_METRICS=15
CACHE_TTL_FILE=300
CACHE_TTL_CONTEXT=300
CACHE_CONTEXT_MAXSIZE=256

# File access restrictions
ALLOWED_FILE_PATH=/root/crm-dashboard
